# ── SERVER ──
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── DATABASE ──
MONGODB_URI=your_mongodb_atlas_connection_string

# ── AUTH ──
JWT_SECRET=generate_a_long_random_string_here
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ── CLOUDINARY (media storage + AI enhancement) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── STRIPE (payments) ──
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ── ANTHROPIC (AI brain - writes content, builds experience) ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── ELEVENLABS (AI voice narration) ──
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=default_voice_id

# ── REPLICATE (photo restoration/colorization) ──
REPLICATE_API_TOKEN=your_replicate_api_token

# ── RESEND (transactional emails) ──
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@giftservice.com

# ── LINKS ──
APP_BASE_URL=https://giftservice.com
DEFAULT_LINK_EXPIRY_HOURS=48
